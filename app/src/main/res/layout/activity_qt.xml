<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/indigo"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로"
            android:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="4dp">
            <TextView
                android:id="@+id/qt_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:singleLine="true"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/qt_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E8C766" />
        </LinearLayout>
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/chapter_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="?attr/colorSurface"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:id="@+id/chapter_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp" />
    </HorizontalScrollView>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/chapter_scroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/qt_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="단락마다 묵상과 기도를 적고 사진을 남겨 보세요. 저장하면 오늘 날짜가 QT 기록으로 남습니다."
                android:textSize="12sp"
                android:textColor="@color/ink_soft"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/btn_divide"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:minHeight="0dp" android:minWidth="0dp"
                android:paddingTop="8dp" android:paddingBottom="8dp" android:paddingHorizontal="14dp"
                android:text="✎ 단락 편집"
                android:textSize="12sp" android:textColor="?attr/colorOnSurface"
                android:includeFontPadding="false"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginBottom="10dp" />

            <!-- 단락 카드들이 여기에 동적으로 추가됨 -->
            <LinearLayout
                android:id="@+id/sections_host"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:minHeight="0dp" android:paddingTop="14dp" android:paddingBottom="14dp"
                android:text="저장 (QT 날짜 기록)"
                android:textSize="15sp" android:textStyle="bold" android:textColor="#FFFFFF"
                android:includeFontPadding="false"
                android:backgroundTint="@color/indigo_light"
                style="@style/Widget.Material3.Button"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btn_delete"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:minHeight="0dp" android:paddingTop="11dp" android:paddingBottom="11dp"
                android:text="이 장의 QT 기록 전체 삭제"
                android:textSize="13sp" android:textColor="#EF5350"
                android:includeFontPadding="false"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
