<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_menu_sheet"
    android:padding="22dp">

    <TextView android:id="@+id/ai_prompt_title"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="구절 프롬프트" android:textSize="18sp" android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"/>

    <TextView android:id="@+id/ai_prompt_sub"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="구절을 AI에 보낼 때 함께 전달되는 지시문입니다."
        android:textSize="12sp" android:textColor="@color/ink_soft"
        android:layout_marginTop="4dp" android:layout_marginBottom="14dp"/>

    <EditText android:id="@+id/ai_prompt_edit"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_note_input"
        android:padding="14dp" android:gravity="top"
        android:minLines="5" android:maxLines="10"
        android:textSize="14sp" android:textColor="?attr/colorOnSurface"
        android:inputType="textMultiLine|textCapSentences"
        android:lineSpacingExtra="3dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="end"
        android:layout_marginTop="16dp">
        <TextView android:id="@+id/ai_prompt_default"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="기본값" android:textColor="@color/ink_soft" android:textSize="14sp"
            android:gravity="center" android:paddingVertical="10dp"
            android:background="?attr/selectableItemBackground"/>
        <TextView android:id="@+id/ai_prompt_cancel"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="취소" android:textColor="@color/ink_soft" android:textSize="14sp"
            android:paddingHorizontal="18dp" android:paddingVertical="10dp"
            android:background="?attr/selectableItemBackground"/>
        <TextView android:id="@+id/ai_prompt_save"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="저장" android:textColor="@color/gold" android:textStyle="bold" android:textSize="14sp"
            android:paddingHorizontal="18dp" android:paddingVertical="10dp"
            android:background="?attr/selectableItemBackground"/>
    </LinearLayout>
</LinearLayout>
