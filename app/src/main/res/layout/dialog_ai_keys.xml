<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_menu_sheet"
        android:padding="22dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="API 키 관리" android:textSize="18sp" android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Gemini · Groq 키를 각각 입력할 수 있습니다. 키는 저장 후 가려서 표시됩니다."
            android:textSize="12sp" android:textColor="@color/ink_soft"
            android:layout_marginTop="4dp" android:layout_marginBottom="18dp"/>

        <!-- Gemini -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Google Gemini" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/gold_soft"/>
        <EditText android:id="@+id/key_gemini_edit"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_note_input" android:padding="14dp"
            android:layout_marginTop="6dp" android:hint="Gemini API 키 붙여넣기"
            android:textSize="13sp" android:textColor="?attr/colorOnSurface"
            android:inputType="textNoSuggestions" android:maxLines="2"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
            <TextView android:id="@+id/status_gemini"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="" android:textSize="12sp" android:textColor="@color/ink_soft"/>
            <TextView android:id="@+id/btn_test_gemini"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="테스트" android:textSize="12sp" android:textStyle="bold" android:textColor="#222222"
                android:paddingHorizontal="14dp" android:paddingVertical="6dp"
                android:background="@drawable/bg_pill_yellow"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginVertical="16dp"/>

        <!-- Groq -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Groq" android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/gold_soft"/>
        <EditText android:id="@+id/key_groq_edit"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_note_input" android:padding="14dp"
            android:layout_marginTop="6dp" android:hint="Groq API 키 붙여넣기 (선택)"
            android:textSize="13sp" android:textColor="?attr/colorOnSurface"
            android:inputType="textNoSuggestions" android:maxLines="2"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="6dp">
            <TextView android:id="@+id/status_groq"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="" android:textSize="12sp" android:textColor="@color/ink_soft"/>
            <TextView android:id="@+id/btn_test_groq"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="테스트" android:textSize="12sp" android:textStyle="bold" android:textColor="#222222"
                android:paddingHorizontal="14dp" android:paddingVertical="6dp"
                android:background="@drawable/bg_pill_yellow"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="end" android:layout_marginTop="20dp">
            <TextView android:id="@+id/keys_cancel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="취소" android:textColor="@color/ink_soft" android:textSize="14sp"
                android:paddingHorizontal="18dp" android:paddingVertical="10dp"
                android:background="?attr/selectableItemBackground"/>
            <TextView android:id="@+id/keys_save"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="저장" android:textColor="@color/gold" android:textStyle="bold" android:textSize="14sp"
                android:paddingHorizontal="18dp" android:paddingVertical="10dp"
                android:background="?attr/selectableItemBackground"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
