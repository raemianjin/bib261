<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_menu_sheet"
    android:padding="22dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="사용할 AI · 모델" android:textSize="18sp" android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="기본은 Gemini입니다. 사용할 제공자와 모델을 선택하세요."
        android:textSize="12sp" android:textColor="@color/ink_soft"
        android:layout_marginTop="4dp" android:layout_marginBottom="16dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="제공자" android:textSize="12sp" android:textColor="@color/gold_soft"
        android:textStyle="bold" android:letterSpacing="0.06"/>
    <RadioGroup android:id="@+id/rg_provider"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="6dp" android:layout_marginBottom="16dp">
        <RadioButton android:id="@+id/rb_gemini" android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:text="Google Gemini"
            android:textColor="?attr/colorOnSurface"/>
        <RadioButton android:id="@+id/rb_groq" android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:text="Groq"
            android:textColor="?attr/colorOnSurface"/>
    </RadioGroup>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="모델" android:textSize="12sp" android:textColor="@color/gold_soft"
        android:textStyle="bold" android:letterSpacing="0.06"/>
    <Spinner android:id="@+id/spinner_model"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_note_input"
        android:padding="10dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="end" android:layout_marginTop="18dp">
        <TextView android:id="@+id/model_cancel"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="취소" android:textColor="@color/ink_soft" android:textSize="14sp"
            android:paddingHorizontal="18dp" android:paddingVertical="10dp"
            android:background="?attr/selectableItemBackground"/>
        <TextView android:id="@+id/model_save"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="저장" android:textColor="@color/gold" android:textStyle="bold" android:textSize="14sp"
            android:paddingHorizontal="18dp" android:paddingVertical="10dp"
            android:background="?attr/selectableItemBackground"/>
    </LinearLayout>
</LinearLayout>
