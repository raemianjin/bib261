<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@color/indigo" android:padding="12dp">
        <TextView android:id="@+id/bulletin_back"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="‹" android:textSize="26sp" android:textColor="@color/white"
            android:paddingHorizontal="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="주보 성경 구절 요약" android:textSize="17sp" android:textStyle="bold"
            android:textColor="@color/white" android:layout_marginStart="6dp"/>
    </LinearLayout>

    <WebView android:id="@+id/bulletin_web"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@color/indigo_dark" android:padding="12dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="가장 큰 / 가운데 본문 말씀이 잘 보이게 한 뒤 아래 버튼을 누르면, 현재 주보 화면을 그대로 AI가 읽어 요약합니다."
            android:textSize="11sp" android:textColor="@color/ink_soft"
            android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/btn_bulletin_ai"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="이 주보 성경 구절 요약" android:textSize="15sp" android:textStyle="bold"
            android:textColor="#222222" android:gravity="center"
            android:paddingVertical="14dp"
            android:background="@drawable/bg_pill_yellow"/>
    </LinearLayout>
</LinearLayout>
